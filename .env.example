# Code Agent Environment Variables
# These override values from config.json

CODE_AGENT_API_KEY=
CODE_AGENT_API_ENDPOINT=https://api.xiaomimimo.com/v1/chat/completions
CODE_AGENT_MODEL=mimo-v2-pro
CODE_AGENT_MAX_STEPS=30
CODE_AGENT_WORKING_DIRECTORY=.
CODE_AGENT_SANDBOX_TYPE=docker
CODE_AGENT_DOCKER_IMAGE=code-agent-sandbox:latest
CODE_AGENT_SANDBOX_TIMEOUT_SEC=300
CODE_AGENT_NETWORK_ENABLED=false
CODE_AGENT_LOG_DIR=./runs
CODE_AGENT_TRAJECTORY_ENABLED=true
