{
  "name": "code-agent",
  "version": "0.1.0",
  "description": "Model-profile-driven CLI coding agent runtime with MiMo optimization",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "mimocoding": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:probe": "tsx src/evals/probe_api.ts",
    "eval:tools": "tsx src/evals/tool_call_eval.ts",
    "eval:coding": "tsx src/evals/coding_eval.ts"
  },
  "dependencies": {
    "openai": "^4.80.0",
    "commander": "^12.0.0",
    "zod": "^3.23.0",
    "dockerode": "^4.0.0",
    "smol-toml": "^1.3.0",
    "glob": "^11.0.0",
    "js-tiktoken": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/dockerode": "^3.3.0",
    "prettier": "^3.3.0"
  }
}
